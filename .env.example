# Copiar a .env (ignorado por git) y completar. En Render, estas mismas
# variables se cargan desde el dashboard del servicio, no desde este archivo.

# Activa los chequeos de producción (SECRET_KEY obligatoria, cookie de sesión
# Secure, debug apagado). Sin esta variable, todo corre en modo desarrollo.
APP_ENV=production

# Clave real generada una sola vez y guardada, nunca en el repo:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Connection string de Postgres. En Render la inyecta el servicio de Postgres
# solo con conectarlo; en local apunta al contenedor de Docker (ver RODO.txt).
DATABASE_URL=postgresql://panacar:panacar_dev_local@127.0.0.1:5432/panacar

# Pendiente (paso 3 del plan en RODO.txt): credenciales de Cloudflare R2.
# R2_ACCOUNT_ID=
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET=
